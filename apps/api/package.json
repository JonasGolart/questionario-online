    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.1",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.3.2",
    "jsonrepair": "^3.14.0",
    "pdf-parse": "^2.4.5",
    "resend": "^6.12.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.3",
    "globals": "^14.0.0",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^3.1.2"
